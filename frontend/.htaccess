<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /~zbalah3/sae4-dweb-di-01-social-AddemZbalah/Cycle-B/frontend/dist/
    
    # Redirige les requêtes vers index.html pour le routage SPA
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>
